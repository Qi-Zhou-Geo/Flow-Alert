## how to use this?
# 1, you alway need to add the "rules" first, then add/remove your file,
#    the git will automatically ingore the "big/untracked"file
# 2, if you alrady add/commit the changes,
#    use the following back to the old version
# git reset --hard <reversion number>


# add the file if you do not want to track it
.idea/
.DS_Store

# Ignore all .mseed files in 'data' and any of its subfolders
data/seismic_data/*.mseed
data/seismic_feature/*.mseed
data/precipitation_data

docs/image/*.cdr

# Ignore all trained model pt and pkl
trained_model/**/*.pt
trained_model/*.pt
trained_model/**/*.pkl
trained_model/*.pkl

